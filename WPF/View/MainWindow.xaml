<Window x:Class="WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CivilizationIdle" Height="450" Width="800" WindowState="Maximized" Background="{DynamicResource AppBackground}">
        <Window.Resources>
            <Color x:Key="ColorBackground">#0E1118</Color>
            <Color x:Key="ColorBackgroundAlt">#141B26</Color>
            <Color x:Key="ColorSurface">#1A2230</Color>
            <Color x:Key="ColorSurfaceAlt">#202A3A</Color>
            <Color x:Key="ColorBorder">#2A3446</Color>
            <Color x:Key="ColorTextPrimary">#E7ECF5</Color>
            <Color x:Key="ColorTextMuted">#9AA8BF</Color>
            <Color x:Key="ColorAccent">#4CC9A8</Color>
            <Color x:Key="ColorAccentStrong">#31A58A</Color>
            <Color x:Key="ColorGold">#D8A24A</Color>
            <Color x:Key="ColorForest">#4EA276</Color>
            <Color x:Key="ColorWood">#B67C4C</Color>
            <Color x:Key="ColorInfo">#4D8DFF</Color>

            <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource ColorBackground}" Offset="0"/>
                <GradientStop Color="{StaticResource ColorBackgroundAlt}" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="CardBackground" Color="{StaticResource ColorSurface}"/>
            <SolidColorBrush x:Key="CardBackgroundAlt" Color="{StaticResource ColorSurfaceAlt}"/>
            <SolidColorBrush x:Key="CardBorder" Color="{StaticResource ColorBorder}"/>
            <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource ColorTextPrimary}"/>
            <SolidColorBrush x:Key="TextMuted" Color="{StaticResource ColorTextMuted}"/>

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}"/>
            <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource ColorAccentStrong}"/>
            <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource ColorGold}"/>
            <SolidColorBrush x:Key="ForestBrush" Color="{StaticResource ColorForest}"/>
            <SolidColorBrush x:Key="WoodBrush" Color="{StaticResource ColorWood}"/>
            <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}"/>
            <SolidColorBrush x:Key="HoverNeutralBrush" Color="#2A3446"/>
            <SolidColorBrush x:Key="HoverGoldBrush" Color="#E0B562"/>

            <local:FontScaleConverter x:Key="FontScaleConverter"/>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackground}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#05070C" BlurRadius="22" ShadowDepth="6" Opacity="0.45"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CollectButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" 
                                            Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource CardBackgroundAlt}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BuildingButtonStyle" TargetType="Button" BasedOn="{StaticResource CollectButtonStyle}">
                <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                <Setter Property="Margin" Value="0,6,0,0"/>
                <Setter Property="Background" Value="{StaticResource CardBackgroundAlt}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="Tag" Value="{StaticResource HoverNeutralBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="UpgradeButtonStyle" TargetType="Button" BasedOn="{StaticResource CollectButtonStyle}">
                <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                <Setter Property="Margin" Value="0,6,0,0"/>
                <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
                <Setter Property="Foreground" Value="#1A1610"/>
                <Setter Property="Tag" Value="{StaticResource HoverGoldBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </Window.Resources>
    

    
    
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Food: " x:Name="FoodText" Grid.Column="0"
                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                    <TextBlock Text="Wood: " x:Name="WoodText" Grid.Column="1"
                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                    <TextBlock Text="Stone: " x:Name="StoneText" Grid.Column="2"
                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                    <TextBlock Text="Gold: " x:Name="GoldText" Grid.Column="3"
                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                    <TextBlock Text="Population: " x:Name="PopulationText" Grid.Column="4"
                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                </Grid>
            </Border>
            
            
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Collect Food" Click="CollectFood_Click" Margin="0,0,10,0"
                            Background="{StaticResource ForestBrush}" Tag="#5BBA88" 
                            Style="{StaticResource CollectButtonStyle}">
                    </Button>
                    <Button Content="Collect Wood" Click="CollectWood_Click" Margin="0,0,10,0"
                            Background="{StaticResource WoodBrush}" Tag="#C8905E"
                            Style="{StaticResource CollectButtonStyle}">
                    </Button>
                    <!--<Button Content="Collect Stone" Click="CollectStone_Click" Margin="5"/>
                <Button Content="Collect Gold" Click="CollectGold_Click" Margin="5"/>-->
                </StackPanel>
            </Border>
            
            
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                        <WrapPanel x:Name="BuildingPanel" Orientation="Vertical"/>
                    </ScrollViewer>
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="UpgradesPanel" Orientation="Vertical"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                <TextBlock Text="Production / sec"
                           FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}"
                           FontWeight="SemiBold" Margin="0,0,0,10"/>
                <ItemsControl x:Name="ProductionPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                       Margin="0,4,0,4" Foreground="{StaticResource TextMuted}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Save" Click="Save_Click" Margin="0,0,10,0"
                            Background="{StaticResource AccentBrush}" Tag="{StaticResource AccentStrongBrush}"
                            Style="{StaticResource CollectButtonStyle}"/>
                    <Button Content="Load" Click="Load_Click"
                            Background="{StaticResource InfoBrush}" Tag="#6BA6FF"
                            Style="{StaticResource CollectButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
        
    </Grid>
</Window>
